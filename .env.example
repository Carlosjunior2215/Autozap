# ===== Aplicação =====
AMBIENTE=desenvolvimento
DEBUG=false

# ===== Banco de dados (async via asyncpg) =====
DATABASE_URL=postgresql+asyncpg://autozap:autozap@localhost:5432/autozap

# ===== Redis / Celery =====
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ===== WhatsApp Cloud API (Meta) =====
WHATSAPP_VERIFY_TOKEN=troque-este-token-de-verificacao
WHATSAPP_APP_SECRET=troque-este-app-secret
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_BASE_URL=https://graph.facebook.com/v21.0

# ===== Anthropic =====
ANTHROPIC_API_KEY=
MODELO_CLASSIFICACAO=claude-haiku-4-5
MODELO_RESPOSTA=claude-sonnet-4-6

# ===== Regras de negócio =====
MINUTOS_SEM_RESPOSTA=0
LIMIAR_CONFIANCA=0.7
MAX_RESPOSTAS_POR_HORA=10

# ===== Administração =====
ADMIN_API_KEY=troque-esta-chave-admin
