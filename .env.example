# ===== Aplicação =====
AMBIENTE=desenvolvimento
DEBUG=false

# ===== Banco de dados (async via asyncpg) =====
DATABASE_URL=postgresql+asyncpg://autozap:autozap@localhost:5432/autozap

# ===== Redis / Celery =====
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ===== WhatsApp Cloud API (Meta) =====
WHATSAPP_VERIFY_TOKEN=troque-este-token-de-verificacao
WHATSAPP_APP_SECRET=troque-este-app-secret
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_BASE_URL=https://graph.facebook.com/v21.0

# ===== Anthropic =====
ANTHROPIC_API_KEY=
MODELO_CLASSIFICACAO=claude-haiku-4-5
MODELO_RESPOSTA=claude-sonnet-4-6

# ===== Regras de negócio =====
# Minutos a aguardar antes de responder automaticamente (0 = responde na hora).
# Com valor > 0, a reavaliação é agendada (countdown); se o cliente ou um
# atendente responder antes, o bot não responde.
MINUTOS_SEM_RESPOSTA=0
LIMIAR_CONFIANCA=0.7
MAX_RESPOSTAS_POR_HORA=10

# ===== Agendamento (slots configuráveis) =====
SERVICOS_OFERECIDOS=Corte de cabelo,Barba,Manicure
AGENDA_HORA_ABERTURA=9
AGENDA_HORA_FECHAMENTO=18
AGENDA_DURACAO_MIN=60
AGENDA_DIAS_A_FRENTE=3
AGENDA_TIMEZONE=America/Sao_Paulo
MAX_SLOTS_OFERECIDOS=9

# ===== Administração =====
ADMIN_API_KEY=troque-esta-chave-admin
